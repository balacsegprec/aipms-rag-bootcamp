# ============================================================================
# AI-PMS RAG Bootcamp — Environment Configuration Template
# 
# INSTRUCTIONS:
# 1. Copy this file to .env (same directory as this file)
# 2. Replace 'xxx_placeholder_xxx' with actual API keys
# 3. NEVER commit .env to git (it's in .gitignore)
# 4. Keep this .env.example file in git (it shows structure only)
# ============================================================================

# ============================================================================
# GROQ API (Primary LLM Provider)
# Sign up: https://console.groq.com
# Get key: https://console.groq.com/keys
# ============================================================================
GROQ_API_KEY=gsk_xxx_placeholder_xxx

# ============================================================================
# GOOGLE AI STUDIO (Fallback LLM Provider)
# Sign up: https://aistudio.google.com
# Get key: https://aistudio.google.com/apikey
# ============================================================================
GOOGLE_API_KEY=AIza_xxx_placeholder_xxx

# ============================================================================
# HUGGINGFACE (For Inference API, Embeddings backup)
# Sign up: https://huggingface.co
# Get token: https://huggingface.co/settings/tokens
# ============================================================================
HF_TOKEN=hf_xxx_placeholder_xxx

# ============================================================================
# OPENROUTER (Backup LLM Provider)
# Sign up: https://openrouter.ai
# Get key: https://openrouter.ai/keys
# ============================================================================
OPENROUTER_API_KEY=sk-or-xxx_placeholder_xxx

# ============================================================================
# CEREBRAS (Backup LLM Provider)
# Sign up: https://cloud.cerebras.ai
# Get key: https://cloud.cerebras.ai/keys
# ============================================================================
CEREBRAS_API_KEY=csk_xxx_placeholder_xxx

# ============================================================================
# DATABASE CONFIGURATION (PostgreSQL on GPREC HPC)
# ============================================================================
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USER=bootcamp_user
DATABASE_PASSWORD=your_secure_password_here
DATABASE_NAME=bootcamp_rag

# ============================================================================
# PATHS & LOCATIONS
# ============================================================================
DATA_PATH=/data/datasets
LOG_PATH=/logs
NOTEBOOKS_PATH=./notebooks
SCRIPTS_PATH=./scripts

# ============================================================================
# MODEL CONFIGURATION
# ============================================================================
# Primary embedding model (small, fast on CPU)
EMBEDDING_MODEL=all-MiniLM-L6-v2

# Alternative embedding models
EMBEDDING_MODEL_BGE=BAAI/bge-large-en-v1.5
EMBEDDING_MODEL_NOMIC=nomic-ai/nomic-embed-text-v1.5

# Cross-encoder reranker (CPU-compatible)
RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-12-v2

# ============================================================================
# LLM MODEL SELECTION
# ============================================================================
# Primary LLM model ID (Groq)
LLM_MODEL_GROQ=llama-3.3-70b-versatile

# Fast LLM for query routing
LLM_MODEL_GROQ_FAST=llama-3.1-8b-instant

# Fallback LLM models
LLM_MODEL_GOOGLE=gemini-2.5-flash
LLM_MODEL_OPENROUTER=deepseek/deepseek-chat-v3-0324:free
LLM_MODEL_CEREBRAS=llama-3.3-70b

# ============================================================================
# RATE LIMITING CONFIGURATION
# ============================================================================
# Groq free tier: ~30 req/min = 2 seconds between requests
GROQ_RATE_LIMIT_DELAY_SECONDS=2

# Google free tier: ~1000/day, but let's be conservative
GOOGLE_RATE_LIMIT_DELAY_SECONDS=1

# HuggingFace free tier: ~100 req/hour
HF_RATE_LIMIT_DELAY_SECONDS=36

# ============================================================================
# EXPERIMENT CONFIGURATION
# ============================================================================
EXPERIMENT_TRACKING_ENABLED=true
MLFLOW_TRACKING_URI=http://localhost:5000

# Number of golden queries for RAGAS evaluation
RAGAS_QUERY_COUNT=50

# Top-K for retrieval (how many chunks to retrieve)
TOP_K_RETRIEVAL=5

# Top-K for reranking (how many to rerank before final selection)
TOP_K_RERANK=30

# ============================================================================
# LOGGING CONFIGURATION
# ============================================================================
LOG_LEVEL=INFO
LOG_FORMAT=json

# ============================================================================
# DEBUG MODE (Set to false in production)
# ============================================================================
DEBUG_MODE=false
VERBOSE_LOGGING=false

# ============================================================================
# API FALLBACK ORDER (comma-separated, order matters)
# ============================================================================
LLM_FALLBACK_ORDER=groq,openrouter,cerebras,google

# ============================================================================
# OPTIONAL: Feature Flags
# ============================================================================
ENABLE_MULTI_HOP_RETRIEVAL=true
ENABLE_LANGGRAPH_AGENT=true
ENABLE_RAGAS_EVALUATION=true
ENABLE_EXPERIMENT_TRACKING=true